{
  "name": "medisathi",
  "version": "1.0.0",
  "description": "WhatsApp medicine reminder bot for elderly (Exotel + Sarvam)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "setup": "npm install && npx prisma generate && npx prisma db push",
    "e2e": "tsx scripts/run-e2e.ts",
    "test:twilio": "tsx scripts/test-twilio.ts",
    "setup:all": "powershell -ExecutionPolicy Bypass -File scripts/setup-and-run.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "node-cron": "^3.0.3",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "twilio": "^5.13.1",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
